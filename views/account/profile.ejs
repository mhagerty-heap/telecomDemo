<%- include('../partials/header') %>
<%- include('../partials/account_nav') %>

<div class="max-w-3xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-extrabold text-gray-900 mb-6">Profile & Settings</h1>

  <% if (typeof saved !== 'undefined' && saved) { %>
    <div class="bg-green-50 border border-green-200 rounded-xl px-5 py-4 mb-6 flex items-center gap-3 text-green-700">
      <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
      <span class="font-medium">Your profile has been updated.</span>
    </div>
  <% } %>

  <form action="/account/profile" method="POST" class="space-y-6">

    <!-- Personal info -->
    <div class="bg-white border rounded-2xl overflow-hidden">
      <div class="bg-gray-50 border-b px-5 py-3">
        <span class="text-xs font-bold text-gray-500 uppercase tracking-wide">Personal Information</span>
      </div>
      <div class="p-5 space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">First name</label>
            <input type="text" name="firstName" value="<%= account.name.split(' ')[0] %>"
              class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Last name</label>
            <input type="text" name="lastName" value="<%= account.name.split(' ')[1] || '' %>"
              class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email address</label>
          <input type="email" name="email" value="<%= account.email %>"
            class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Phone number</label>
          <input type="tel" name="phone" value="<%= account.phone %>"
            class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition">
        </div>
      </div>
    </div>

    <!-- Address -->
    <div class="bg-white border rounded-2xl overflow-hidden">
      <div class="bg-gray-50 border-b px-5 py-3">
        <span class="text-xs font-bold text-gray-500 uppercase tracking-wide">Service Address</span>
      </div>
      <div class="p-5 space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Street address</label>
          <input type="text" name="address" value="<%= account.address.street %>"
            class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition">
        </div>
        <div class="grid grid-cols-6 gap-4">
          <div class="col-span-3">
            <label class="block text-sm font-medium text-gray-700 mb-1">City</label>
            <input type="text" name="city" value="<%= account.address.city %>"
              class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition">
          </div>
          <div class="col-span-1">
            <label class="block text-sm font-medium text-gray-700 mb-1">State</label>
            <input type="text" name="state" value="<%= account.address.state %>" maxlength="2"
              class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition uppercase">
          </div>
          <div class="col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">ZIP</label>
            <input type="text" name="zip" value="<%= account.address.zip %>" maxlength="5"
              class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition">
          </div>
        </div>
      </div>
    </div>

    <!-- Notifications -->
    <div class="bg-white border rounded-2xl overflow-hidden">
      <div class="bg-gray-50 border-b px-5 py-3">
        <span class="text-xs font-bold text-gray-500 uppercase tracking-wide">Notification Preferences</span>
      </div>
      <div class="p-5 space-y-3">
        <% [
          { name: 'notif_bill', label: 'Bill due reminders', checked: true },
          { name: 'notif_usage', label: 'Data usage alerts', checked: true },
          { name: 'notif_promo', label: 'Promotions and offers', checked: false },
          { name: 'notif_outage', label: 'Network outage alerts', checked: true }
        ].forEach(n => { %>
          <label class="flex items-center justify-between cursor-pointer">
            <span class="text-sm text-gray-700"><%= n.label %></span>
            <input type="checkbox" name="<%= n.name %>" value="1" <%= n.checked ? 'checked' : '' %>
              class="w-4 h-4 accent-nexus-500">
          </label>
        <% }) %>
      </div>
    </div>

    <!-- Password -->
    <div class="bg-white border rounded-2xl overflow-hidden">
      <div class="bg-gray-50 border-b px-5 py-3">
        <span class="text-xs font-bold text-gray-500 uppercase tracking-wide">Change Password</span>
      </div>
      <div class="p-5 space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Current password</label>
          <input type="password" name="currentPassword" placeholder="••••••••"
            class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition">
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">New password</label>
            <input type="password" name="newPassword" placeholder="••••••••"
              class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Confirm new password</label>
            <input type="password" name="confirmPassword" placeholder="••••••••"
              class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition">
          </div>
        </div>
      </div>
    </div>

    <div class="flex justify-between items-center">
      <a href="/account" id="link-profile-cancel" class="text-sm text-gray-400 hover:text-gray-600">← Back to account</a>
      <button type="submit" id="btn-profile-save"
        class="bg-nexus-500 hover:bg-nexus-600 text-white font-bold px-8 py-3 rounded-xl transition">
        Save Changes
      </button>
    </div>

  </form>
</div>

<%- include('../partials/footer') %>
