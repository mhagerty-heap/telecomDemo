<%- include('../partials/header') %>
<%- include('../partials/account_nav') %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-extrabold text-gray-900 mb-6">Bill & Payments</h1>

  <!-- Success banner -->
  <% if (paid) { %>
    <div class="bg-green-50 border border-green-200 rounded-xl px-5 py-4 mb-6 flex items-center gap-3 text-green-700">
      <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
      <span class="font-medium">Payment of $<%= account.billing.balance.toFixed(2) %> was successful. Thank you!</span>
    </div>
  <% } %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- Main: current bill -->
    <div class="lg:col-span-2 space-y-6">

      <!-- Current bill card -->
      <div class="bg-white border rounded-2xl overflow-hidden">
        <div class="bg-gray-50 border-b px-5 py-3 flex justify-between items-center">
          <span class="text-xs font-bold text-gray-500 uppercase tracking-wide">Current Bill</span>
          <span class="text-xs text-gray-400">Billing period: Jun 8 – Jul 7, 2025</span>
        </div>
        <div class="p-5 space-y-3">
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">Nexus Unlimited Plan</span>
            <span class="font-medium text-gray-800">$55.00</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">Line 1 — Alex</span>
            <span class="font-medium text-gray-800">included</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">Line 2 — Jordan</span>
            <span class="font-medium text-gray-800">included</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">Taxes & regulatory fees</span>
            <span class="font-medium text-gray-800">included</span>
          </div>
          <div class="border-t pt-3 flex justify-between font-bold text-base">
            <span>Total due Jul 8, 2025</span>
            <span class="text-nexus-600">$<%= account.billing.balance.toFixed(2) %></span>
          </div>
        </div>

        <% if (!paid) { %>
          <div class="px-5 pb-5">
            <form action="/account/bill/pay" method="POST">
              <button type="submit" id="btn-bill-pay-now"
                class="w-full bg-nexus-500 hover:bg-nexus-600 text-white font-bold py-3 rounded-xl transition">
                Pay $<%= account.billing.balance.toFixed(2) %> Now
              </button>
            </form>
          </div>
        <% } %>
      </div>

      <!-- AutoPay toggle -->
      <div class="bg-white border rounded-2xl p-5">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="font-bold text-gray-900">AutoPay</h3>
            <p class="text-sm text-gray-400 mt-0.5">Never miss a payment. We'll charge your card automatically each month.</p>
          </div>
          <button onclick="toggleAutopay()" id="autopay-btn"
            class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors
              <%= account.billing.autopay ? 'bg-nexus-500' : 'bg-gray-200' %>">
            <span id="autopay-dot" class="inline-block h-4 w-4 transform rounded-full bg-white shadow transition-transform
              <%= account.billing.autopay ? 'translate-x-6' : 'translate-x-1' %>"></span>
          </button>
        </div>
        <% if (!account.billing.autopay) { %>
          <div class="mt-3 text-xs text-gray-400">
            AutoPay is currently <strong class="text-gray-600">off</strong>. Enable it to save time every month.
          </div>
        <% } %>
      </div>

      <!-- Payment method -->
      <div class="bg-white border rounded-2xl p-5">
        <div class="flex justify-between items-center mb-4">
          <h3 class="font-bold text-gray-900">Payment method</h3>
          <button id="btn-bill-update-payment" class="text-xs text-nexus-500 hover:underline font-medium">Update</button>
        </div>
        <div class="flex items-center gap-3">
          <div class="bg-gray-100 rounded-lg px-3 py-2 font-bold text-gray-700 text-sm tracking-widest">VISA</div>
          <div>
            <div class="text-sm font-medium text-gray-800">•••• •••• •••• <%= account.billing.paymentMethod.last4 %></div>
            <div class="text-xs text-gray-400">Expires 09/27</div>
          </div>
        </div>
      </div>

    </div>

    <!-- Right: payment history -->
    <div class="space-y-6">
      <div class="bg-white border rounded-2xl overflow-hidden">
        <div class="bg-gray-50 border-b px-5 py-3">
          <span class="text-xs font-bold text-gray-500 uppercase tracking-wide">Payment History</span>
        </div>
        <div class="divide-y">
          <% [
            { date: 'Jun 8, 2025', amount: 55.00, status: 'Paid' },
            { date: 'May 8, 2025', amount: 55.00, status: 'Paid' },
            { date: 'Apr 8, 2025', amount: 55.00, status: 'Paid' },
            { date: 'Mar 8, 2025', amount: 55.00, status: 'Paid' },
            { date: 'Feb 8, 2025', amount: 55.00, status: 'Paid' },
            { date: 'Jan 8, 2025', amount: 55.00, status: 'Paid' }
          ].forEach(p => { %>
            <div class="flex items-center justify-between px-5 py-3 text-sm">
              <div>
                <div class="font-medium text-gray-800"><%= p.date %></div>
                <span class="text-xs text-green-600 font-medium"><%= p.status %></span>
              </div>
              <div class="font-semibold text-gray-700">$<%= p.amount.toFixed(2) %></div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  let autopayOn = <%= account.billing.autopay %>;
  function toggleAutopay() {
    autopayOn = !autopayOn;
    const btn = document.getElementById('autopay-btn');
    const dot = document.getElementById('autopay-dot');
    btn.classList.toggle('bg-nexus-500', autopayOn);
    btn.classList.toggle('bg-gray-200', !autopayOn);
    dot.classList.toggle('translate-x-6', autopayOn);
    dot.classList.toggle('translate-x-1', !autopayOn);
  }
</script>

<%- include('../partials/footer') %>
