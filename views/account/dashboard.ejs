<%- include('../partials/header') %>
<%- include('../partials/account_nav') %>

<div class="max-w-6xl mx-auto px-4 py-8">

  <!-- Welcome bar -->
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-extrabold text-gray-900">Welcome back, <%= account.name.split(' ')[0] %></h1>
      <p class="text-gray-400 text-sm mt-0.5">Account #<%= account.accountId %></p>
    </div>
    <% if (!account.billing.autopay) { %>
      <div class="bg-yellow-50 border border-yellow-200 rounded-xl px-4 py-2.5 flex items-center gap-2 text-sm">
        <svg class="w-4 h-4 text-yellow-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
        </svg>
        <span class="text-yellow-700">Bill due <strong>Jul 8</strong> — <a href="/account/bill" id="link-dashboard-pay-now" class="underline font-semibold">Pay now</a></span>
      </div>
    <% } %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- LEFT: Usage + Bill -->
    <div class="lg:col-span-2 space-y-6">

      <!-- Usage card -->
      <div class="bg-white border rounded-2xl p-6">
        <div class="flex items-center justify-between mb-5">
          <h2 class="font-bold text-gray-900">This billing cycle</h2>
          <span class="text-xs text-gray-400"><%= account.usage.cycleStart %> – <%= account.usage.cycleEnd %></span>
        </div>

        <!-- Data -->
        <div class="mb-5">
          <div class="flex justify-between items-center mb-1.5">
            <span class="text-sm font-medium text-gray-700">Mobile Data</span>
            <span class="text-sm text-gray-500">
              <% if (account.usage.data.unlimited) { %>
                <strong class="text-nexus-600"><%= account.usage.data.used %> GB</strong> used · Unlimited
              <% } else { %>
                <strong class="text-nexus-600"><%= account.usage.data.used %></strong> / <%= account.usage.data.total %> GB
              <% } %>
            </span>
          </div>
          <div class="usage-bar">
            <% const dataPercent = account.usage.data.unlimited ? Math.min((account.usage.data.used / 20) * 100, 100) : (account.usage.data.used / account.usage.data.total) * 100 %>
            <div class="usage-bar-fill" style="width: <%= dataPercent %>%"></div>
          </div>
          <p class="text-xs text-gray-400 mt-1">Unlimited high-speed data on your plan</p>
        </div>

        <!-- Hotspot -->
        <div class="mb-5">
          <div class="flex justify-between items-center mb-1.5">
            <span class="text-sm font-medium text-gray-700">Mobile Hotspot</span>
            <span class="text-sm text-gray-500">
              <strong class="<%= account.usage.hotspot.used / account.usage.hotspot.total > 0.8 ? 'text-red-500' : 'text-nexus-600' %>">
                <%= account.usage.hotspot.used %> GB
              </strong> / <%= account.usage.hotspot.total %> GB
            </span>
          </div>
          <div class="usage-bar">
            <% const hotspotPercent = (account.usage.hotspot.used / account.usage.hotspot.total) * 100 %>
            <div class="usage-bar-fill <%= hotspotPercent > 80 ? 'warning' : '' %>" style="width: <%= hotspotPercent %>%"></div>
          </div>
          <% if (hotspotPercent > 75) { %>
            <p class="text-xs text-yellow-600 mt-1 font-medium">⚠ Running low — <%= (account.usage.hotspot.total - account.usage.hotspot.used).toFixed(1) %> GB remaining</p>
          <% } %>
        </div>

        <!-- Talk & Text -->
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-gray-50 rounded-xl p-4">
            <div class="text-xs text-gray-400 mb-1">Talk</div>
            <div class="text-xl font-bold text-gray-900"><%= account.usage.talk.used %> <span class="text-sm font-normal text-gray-400">min</span></div>
            <div class="text-xs text-gray-400 mt-0.5">Unlimited</div>
          </div>
          <div class="bg-gray-50 rounded-xl p-4">
            <div class="text-xs text-gray-400 mb-1">Text</div>
            <div class="text-xl font-bold text-gray-900"><%= account.usage.text.used.toLocaleString() %> <span class="text-sm font-normal text-gray-400">msg</span></div>
            <div class="text-xs text-gray-400 mt-0.5">Unlimited</div>
          </div>
        </div>
      </div>

      <!-- Lines summary -->
      <div class="bg-white border rounded-2xl p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-bold text-gray-900">Lines on your account</h2>
          <a href="/account/lines" id="link-dashboard-manage-lines" class="text-xs text-nexus-500 hover:underline font-medium">Manage →</a>
        </div>
        <div class="space-y-3">
          <% account.lines.forEach(line => { %>
            <div class="flex items-center justify-between py-2 border-b last:border-0">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 bg-nexus-100 rounded-full flex items-center justify-center text-nexus-600 font-bold text-sm">
                  <%= line.name.charAt(0) %>
                </div>
                <div>
                  <div class="font-medium text-gray-800 text-sm"><%= line.name %></div>
                  <div class="text-xs text-gray-400"><%= line.number %></div>
                </div>
              </div>
              <div class="text-right">
                <div class="text-xs text-gray-500"><%= line.device %></div>
                <span class="inline-block mt-0.5 px-2 py-0.5 rounded-full text-xs font-medium
                  <%= line.status === 'active' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
                  <%= line.status %>
                </span>
              </div>
            </div>
          <% }) %>
        </div>
        <a href="/account/lines" id="link-dashboard-add-line" class="mt-4 flex items-center gap-1.5 text-sm text-nexus-500 hover:underline font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Add a line
        </a>
      </div>

    </div>

    <!-- RIGHT: Bill + Plan + Quick links -->
    <div class="space-y-6">

      <!-- Bill card -->
      <div class="bg-white border rounded-2xl p-6">
        <h2 class="font-bold text-gray-900 mb-4">Current bill</h2>
        <div class="text-4xl font-extrabold text-gray-900 mb-1">$<%= account.billing.balance.toFixed(2) %></div>
        <div class="text-sm text-gray-400 mb-5">Due <strong class="text-gray-700">Jul 8, 2025</strong></div>
        <% if (!account.billing.autopay) { %>
          <a href="/account/bill" id="link-dashboard-pay-now"
            class="block w-full text-center bg-nexus-500 hover:bg-nexus-600 text-white font-bold py-2.5 rounded-xl transition text-sm mb-3">
            Pay Now
          </a>
          <a href="/account/bill" id="link-dashboard-setup-autopay"
            class="block w-full text-center bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2.5 rounded-xl transition text-sm">
            Set Up AutoPay
          </a>
        <% } else { %>
          <div class="flex items-center gap-2 text-sm text-green-600 font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            AutoPay is on — you're all set
          </div>
        <% } %>
        <div class="mt-4 pt-4 border-t text-xs text-gray-400">
          Last payment: $<%= account.billing.lastPayment.amount.toFixed(2) %> on <%= account.billing.lastPayment.date %>
        </div>
      </div>

      <!-- Plan card -->
      <div class="bg-white border rounded-2xl p-6">
        <h2 class="font-bold text-gray-900 mb-3">Your plan</h2>
        <div class="text-lg font-extrabold text-nexus-600 mb-0.5">Nexus <%= account.plan.name %></div>
        <div class="text-sm text-gray-400 mb-4">$<%= account.plan.price %>/mo · Renews <%= account.plan.renewalDate %></div>
        <a href="/account/plan" id="link-dashboard-upgrade-plan"
          class="block w-full text-center bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2.5 rounded-xl transition text-sm">
          View / Upgrade Plan
        </a>
      </div>

      <!-- Quick links -->
      <div class="bg-white border rounded-2xl p-6">
        <h2 class="font-bold text-gray-900 mb-4">Quick links</h2>
        <div class="space-y-2">
          <% [
            { label: 'View my devices', href: '/account/devices', icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z', quickId: 'link-dashboard-quick-devices' },
            { label: 'Edit profile', href: '/account/profile', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z', quickId: 'link-dashboard-quick-profile' },
            { label: 'Get support', href: '/support', icon: 'M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0z', quickId: 'link-dashboard-quick-support' },
            { label: 'Shop new devices', href: '/devices', icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z', quickId: 'link-dashboard-quick-shop-devices' }
          ].forEach(link => { %>
            <a href="<%= link.href %>" id="<%= link.quickId %>" class="flex items-center gap-3 py-2 text-sm text-gray-600 hover:text-nexus-600 transition group">
              <svg class="w-4 h-4 text-gray-400 group-hover:text-nexus-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= link.icon %>"/>
              </svg>
              <%= link.label %>
            </a>
          <% }) %>
        </div>
      </div>

    </div>
  </div>
</div>

<%- include('../partials/footer') %>
