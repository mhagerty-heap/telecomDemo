<%- include('../partials/header') %>

<div class="bg-white border-b px-4 py-3">
  <div class="max-w-3xl mx-auto text-sm text-gray-500">
    <a href="/support" class="hover:text-nexus-500">Support</a>
    <span class="mx-2">›</span>
    <span class="text-gray-800 font-medium">Outage Checker</span>
  </div>
</div>

<div class="max-w-3xl mx-auto px-4 py-10">
  <h1 class="text-2xl font-extrabold text-gray-900 mb-2">Check for outages in your area</h1>
  <p class="text-gray-500 mb-8">Enter your ZIP code to see current network status near you.</p>

  <!-- ZIP form -->
  <form action="/support/outages" method="GET" class="flex gap-3 mb-8">
    <input type="text" name="zip" value="<%= zip %>"
      placeholder="Enter ZIP code" maxlength="5" inputmode="numeric"
      class="flex-1 border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition">
    <button type="submit" id="btn-outages-check"
      class="bg-nexus-500 hover:bg-nexus-600 text-white font-bold px-6 py-3 rounded-xl transition text-sm">
      Check
    </button>
  </form>

  <!-- Status result -->
  <% if (status) { %>
    <div class="rounded-2xl border p-6 mb-8 flex items-start gap-4
      <%= status.type === 'ok' ? 'bg-green-50 border-green-200' : 'bg-yellow-50 border-yellow-200' %>">
      <% if (status.type === 'ok') { %>
        <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <div>
          <h2 class="font-bold text-green-800 mb-1">All clear — ZIP <%= zip %></h2>
          <p class="text-green-700 text-sm"><%= status.message %></p>
          <p class="text-green-600 text-xs mt-2">Last checked: just now · Next check in 5 minutes</p>
        </div>
      <% } else { %>
        <div class="w-10 h-10 bg-yellow-100 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
          </svg>
        </div>
        <div>
          <h2 class="font-bold text-yellow-800 mb-1">Service disruption — ZIP <%= zip %></h2>
          <p class="text-yellow-700 text-sm"><%= status.message %></p>
          <p class="text-yellow-600 text-xs mt-3 font-medium">Estimated resolution: within 2 hours</p>
          <p class="text-yellow-600 text-xs mt-1">Affected services: Mobile data, Hotspot</p>
        </div>
      <% } %>
    </div>
  <% } %>

  <!-- Network status overview -->
  <div class="bg-white border rounded-2xl overflow-hidden mb-8">
    <div class="bg-gray-50 border-b px-5 py-3">
      <span class="text-xs font-bold text-gray-500 uppercase tracking-wide">Current System Status</span>
    </div>
    <div class="divide-y">
      <% [
        { service: '5G Network', status: 'Operational', ok: true },
        { service: '4G LTE Network', status: 'Operational', ok: true },
        { service: 'Voice & Calling', status: 'Operational', ok: true },
        { service: 'SMS & MMS', status: 'Operational', ok: true },
        { service: 'Mobile Hotspot', status: status && status.type === 'warning' ? 'Degraded Performance' : 'Operational', ok: !(status && status.type === 'warning') },
        { service: 'Account Portal', status: 'Operational', ok: true },
        { service: 'Nexus Mobile App', status: 'Operational', ok: true }
      ].forEach(row => { %>
        <div class="flex items-center justify-between px-5 py-3.5">
          <span class="text-sm text-gray-700"><%= row.service %></span>
          <span class="flex items-center gap-1.5 text-xs font-semibold
            <%= row.ok ? 'text-green-600' : 'text-yellow-600' %>">
            <span class="w-2 h-2 rounded-full inline-block
              <%= row.ok ? 'bg-green-500' : 'bg-yellow-400' %>"></span>
            <%= row.status %>
          </span>
        </div>
      <% }) %>
    </div>
  </div>

  <!-- Recent incidents -->
  <div class="bg-white border rounded-2xl overflow-hidden">
    <div class="bg-gray-50 border-b px-5 py-3">
      <span class="text-xs font-bold text-gray-500 uppercase tracking-wide">Recent Incidents</span>
    </div>
    <div class="divide-y">
      <% [
        { date: 'Jun 12, 2025', title: 'Intermittent data outage — Pacific Northwest', resolved: true, duration: '47 min' },
        { date: 'May 28, 2025', title: 'Elevated call drop rates — Southeast region', resolved: true, duration: '1 hr 12 min' },
        { date: 'May 3, 2025', title: 'SMS delivery delays — nationwide', resolved: true, duration: '23 min' }
      ].forEach(inc => { %>
        <div class="px-5 py-4">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-medium text-gray-800"><%= inc.title %></p>
              <p class="text-xs text-gray-400 mt-0.5"><%= inc.date %> · Resolved in <%= inc.duration %></p>
            </div>
            <span class="flex-shrink-0 text-xs font-semibold text-green-600 bg-green-100 px-2.5 py-1 rounded-full">Resolved</span>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="mt-6 text-center">
    <p class="text-sm text-gray-400">Still having trouble?
      <a href="/support/contact" id="link-outages-contact" class="text-nexus-500 hover:underline font-medium">Contact us →</a>
    </p>
  </div>
</div>

<%- include('../partials/footer') %>
