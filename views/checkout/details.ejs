<%- include('../partials/header') %>
<%- include('../partials/checkout_steps') %>

<div class="max-w-2xl mx-auto px-4 py-10">
  <h1 class="text-2xl font-extrabold text-gray-900 mb-1">Your information</h1>
  <p class="text-gray-500 mb-8">We'll use this to set up your account and ship your SIM.</p>

  <form action="/checkout/details" method="POST" novalidate class="space-y-6">

    <!-- Name -->
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="firstName">First name</label>
        <input type="text" id="firstName" name="firstName"
          value="<%= formData.firstName || '' %>"
          autocomplete="given-name"
          placeholder="Alex"
          class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition
            <%= errors.firstName ? 'border-red-400 bg-red-50' : 'border-gray-300' %>">
        <% if (errors.firstName) { %>
          <p class="text-red-500 text-xs mt-1"><%= errors.firstName %></p>
        <% } %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="lastName">Last name</label>
        <input type="text" id="lastName" name="lastName"
          value="<%= formData.lastName || '' %>"
          autocomplete="family-name"
          placeholder="Johnson"
          class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition
            <%= errors.lastName ? 'border-red-400 bg-red-50' : 'border-gray-300' %>">
        <% if (errors.lastName) { %>
          <p class="text-red-500 text-xs mt-1"><%= errors.lastName %></p>
        <% } %>
      </div>
    </div>

    <!-- Email -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1" for="email">Email address</label>
      <input type="email" id="email" name="email"
        value="<%= formData.email || '' %>"
        autocomplete="email"
        placeholder="you@example.com"
        class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition
          <%= errors.email ? 'border-red-400 bg-red-50' : 'border-gray-300' %>">
      <% if (errors.email) { %>
        <p class="text-red-500 text-xs mt-1"><%= errors.email %></p>
      <% } %>
    </div>

    <!-- Phone -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1" for="phone">Mobile number</label>
      <input type="tel" id="phone" name="phone"
        value="<%= formData.phone || '' %>"
        autocomplete="tel"
        placeholder="(555) 000-0000"
        class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition
          <%= errors.phone ? 'border-red-400 bg-red-50' : 'border-gray-300' %>">
      <% if (errors.phone) { %>
        <p class="text-red-500 text-xs mt-1"><%= errors.phone %></p>
      <% } %>
    </div>

    <!-- Address -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1" for="address">Street address</label>
      <input type="text" id="address" name="address"
        value="<%= formData.address || '' %>"
        autocomplete="street-address"
        placeholder="742 Evergreen Terrace"
        class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition
          <%= errors.address ? 'border-red-400 bg-red-50' : 'border-gray-300' %>">
      <% if (errors.address) { %>
        <p class="text-red-500 text-xs mt-1"><%= errors.address %></p>
      <% } %>
    </div>

    <!-- City / State / ZIP -->
    <div class="grid grid-cols-6 gap-4">
      <div class="col-span-3">
        <label class="block text-sm font-medium text-gray-700 mb-1" for="city">City</label>
        <input type="text" id="city" name="city"
          value="<%= formData.city || '' %>"
          autocomplete="address-level2"
          placeholder="Springfield"
          class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition
            <%= errors.city ? 'border-red-400 bg-red-50' : 'border-gray-300' %>">
        <% if (errors.city) { %>
          <p class="text-red-500 text-xs mt-1"><%= errors.city %></p>
        <% } %>
      </div>
      <div class="col-span-1">
        <label class="block text-sm font-medium text-gray-700 mb-1" for="state">State</label>
        <input type="text" id="state" name="state"
          value="<%= formData.state || '' %>"
          autocomplete="address-level1"
          placeholder="IL"
          maxlength="2"
          class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition uppercase
            <%= errors.state ? 'border-red-400 bg-red-50' : 'border-gray-300' %>">
        <% if (errors.state) { %>
          <p class="text-red-500 text-xs mt-1"><%= errors.state %></p>
        <% } %>
      </div>
      <div class="col-span-2">
        <label class="block text-sm font-medium text-gray-700 mb-1" for="zip">ZIP code</label>
        <input type="text" id="zip" name="zip"
          value="<%= formData.zip || '' %>"
          autocomplete="postal-code"
          placeholder="62701"
          maxlength="5"
          inputmode="numeric"
          class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition
            <%= errors.zip ? 'border-red-400 bg-red-50' : 'border-gray-300' %>">
        <% if (errors.zip) { %>
          <p class="text-red-500 text-xs mt-1"><%= errors.zip %></p>
        <% } %>
      </div>
    </div>

    <!-- Port-in number -->
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
      <label class="flex items-center gap-3 cursor-pointer">
        <input type="checkbox" name="portIn" id="portIn" value="1"
          <%= formData.portIn ? 'checked' : '' %>
          onchange="togglePortIn()"
          class="w-4 h-4 accent-nexus-500">
        <span class="text-sm font-medium text-gray-700">I want to keep my current phone number</span>
      </label>
      <div id="portInFields" class="<%= formData.portIn ? '' : 'hidden' %> mt-4">
        <label class="block text-sm font-medium text-gray-700 mb-1" for="currentNumber">Current phone number</label>
        <input type="tel" id="currentNumber" name="currentNumber"
          value="<%= formData.currentNumber || '' %>"
          placeholder="(555) 000-0000"
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-nexus-500 transition">
        <p class="text-xs text-gray-400 mt-1">Port-in usually completes within 30 minutes.</p>
      </div>
    </div>

    <div class="flex justify-between pt-2">
      <a href="/checkout/device" id="link-checkout-details-back" class="text-gray-500 hover:text-gray-800 font-medium py-3 px-5 rounded-xl border border-gray-200 hover:border-gray-300 transition">
        ← Back
      </a>
      <button type="submit" id="btn-checkout-details-continue"
        class="bg-nexus-500 hover:bg-nexus-600 text-white font-bold px-8 py-3 rounded-xl transition">
        Review Order →
      </button>
    </div>

  </form>
</div>

<script>
  function togglePortIn() {
    const fields = document.getElementById('portInFields');
    fields.classList.toggle('hidden', !document.getElementById('portIn').checked);
  }
</script>

<%- include('../partials/footer') %>
