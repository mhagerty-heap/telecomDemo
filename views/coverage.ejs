<%- include('partials/header') %>

<!-- Header -->
<section class="bg-gradient-to-br from-nexus-900 to-nexus-700 text-white py-14 px-4 text-center">
  <h1 class="text-4xl font-extrabold mb-3">Coverage Map</h1>
  <p class="text-blue-100 text-lg max-w-xl mx-auto">Check 5G and LTE coverage anywhere in the US.</p>

  <!-- ZIP search -->
  <form id="coverage-form" onsubmit="checkCoverage(event)" class="max-w-sm mx-auto mt-6 flex gap-3">
    <input type="text" id="zip-input" placeholder="Enter ZIP code" maxlength="5" inputmode="numeric"
      class="flex-1 text-gray-800 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-white/50 shadow">
    <button type="submit" id="btn-coverage-check"
      class="bg-white text-nexus-700 font-bold px-5 py-3 rounded-xl hover:bg-blue-50 transition text-sm">
      Check
    </button>
  </form>
</section>

<!-- Coverage type legend + map -->
<section class="py-10 px-4 bg-gray-50">
  <div class="max-w-6xl mx-auto">

    <!-- Legend tabs -->
    <div class="flex flex-wrap gap-3 mb-6 items-center">
      <span class="text-sm font-semibold text-gray-700 mr-2">Show:</span>
      <% [
        { label: '5G Ultra', color: 'bg-purple-500' },
        { label: '5G Extended', color: 'bg-nexus-500' },
        { label: '4G LTE', color: 'bg-green-500' },
        { label: 'Extended LTE', color: 'bg-yellow-400' }
      ].forEach(layer => { %>
        <label class="flex items-center gap-2 cursor-pointer bg-white border rounded-lg px-3 py-1.5 text-sm font-medium text-gray-600 hover:border-nexus-300 transition">
          <input type="checkbox" checked class="accent-nexus-500">
          <span class="w-3 h-3 rounded-full <%= layer.color %>"></span>
          <%= layer.label %>
        </label>
      <% }) %>
    </div>

    <!-- Simulated map -->
    <div class="bg-white border rounded-2xl overflow-hidden shadow-sm relative">
      <!-- Map canvas (CSS-drawn, no API needed) -->
      <div id="map-area" class="relative w-full bg-slate-100 overflow-hidden" style="height: 420px;">

        <!-- US outline approximation using SVG -->
        <svg viewBox="0 0 800 450" class="w-full h-full" xmlns="http://www.w3.org/2000/svg">

          <!-- Ocean background -->
          <rect width="800" height="450" fill="#dbeafe"/>

          <!-- Rough US landmass -->
          <path d="M120,80 L680,80 L730,140 L720,200 L700,260 L680,320 L600,380 L500,400 L400,410 L300,400 L200,380 L130,320 L90,260 L80,180 Z"
            fill="#e2e8f0" stroke="#cbd5e1" stroke-width="2"/>

          <!-- 5G Ultra coverage blobs (major metros) -->
          <ellipse cx="580" cy="180" rx="55" ry="45" fill="#a855f7" opacity="0.5"/>
          <ellipse cx="620" cy="220" rx="40" ry="35" fill="#a855f7" opacity="0.45"/>
          <ellipse cx="250" cy="160" rx="60" ry="50" fill="#a855f7" opacity="0.5"/>
          <ellipse cx="460" cy="200" rx="50" ry="40" fill="#a855f7" opacity="0.5"/>
          <ellipse cx="340" cy="290" rx="45" ry="38" fill="#a855f7" opacity="0.45"/>

          <!-- 5G Extended -->
          <ellipse cx="400" cy="200" rx="200" ry="140" fill="#4361ee" opacity="0.3"/>
          <ellipse cx="550" cy="240" rx="160" ry="120" fill="#4361ee" opacity="0.25"/>
          <ellipse cx="230" cy="220" rx="130" ry="110" fill="#4361ee" opacity="0.3"/>

          <!-- 4G LTE (broad) -->
          <ellipse cx="400" cy="240" rx="310" ry="190" fill="#22c55e" opacity="0.2"/>

          <!-- Extended LTE -->
          <ellipse cx="400" cy="250" rx="360" ry="220" fill="#facc15" opacity="0.15"/>

          <!-- City dots -->
          <% [
            { x: 580, y: 180, name: 'New York' },
            { x: 250, y: 160, name: 'Los Angeles' },
            { x: 460, y: 200, name: 'Chicago' },
            { x: 340, y: 290, name: 'Houston' },
            { x: 620, y: 220, name: 'Philadelphia' },
            { x: 530, y: 260, name: 'Atlanta' },
            { x: 190, y: 200, name: 'San Francisco' },
            { x: 390, y: 170, name: 'Minneapolis' },
            { x: 310, y: 220, name: 'Kansas City' },
            { x: 650, y: 290, name: 'Miami' }
          ].forEach(city => { %>
            <circle cx="<%= city.x %>" cy="<%= city.y %>" r="5" fill="#1e293b" opacity="0.7"/>
            <text x="<%= city.x + 7 %>" y="<%= city.y + 4 %>" font-size="9" fill="#334155" font-family="sans-serif"><%= city.name %></text>
          <% }) %>

          <!-- ZIP result pin (shown via JS) -->
          <g id="zip-pin" style="display:none">
            <circle id="pin-circle" cx="400" cy="240" r="12" fill="#ef4444" opacity="0.8"/>
            <circle id="pin-ring" cx="400" cy="240" r="18" fill="none" stroke="#ef4444" stroke-width="2" opacity="0.5"/>
            <text id="pin-label" x="400" y="270" font-size="11" fill="#1e293b" font-family="sans-serif" font-weight="bold" text-anchor="middle">ZIP: ----</text>
          </g>

        </svg>

        <!-- Coverage result overlay -->
        <div id="coverage-result" class="hidden absolute top-4 left-4 bg-white rounded-xl shadow-lg border p-4 max-w-xs">
          <div id="result-badge" class="flex items-center gap-2 mb-2">
            <span id="result-dot" class="w-3 h-3 rounded-full bg-purple-500"></span>
            <span id="result-type" class="font-bold text-gray-900 text-sm">5G Ultra</span>
          </div>
          <p id="result-desc" class="text-xs text-gray-500"></p>
          <a href="/checkout/plan" id="link-coverage-result-cta" class="mt-3 block text-center text-xs bg-nexus-500 text-white font-bold py-2 rounded-lg hover:bg-nexus-600 transition">
            Start with Nexus →
          </a>
        </div>
      </div>

      <!-- Map footer -->
      <div class="border-t px-5 py-3 bg-white flex flex-wrap gap-4 text-xs text-gray-400">
        <span>Coverage as of June 2025</span>
        <span>·</span>
        <span>Indoor coverage may vary</span>
        <span>·</span>
        <span>International roaming not shown</span>
      </div>
    </div>

  </div>
</section>

<!-- Coverage stats -->
<section class="py-12 px-4 bg-white">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-extrabold text-gray-900 text-center mb-10">Built for the whole country</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <% [
        { stat: '99%', label: 'US population covered' },
        { stat: '5G', label: 'in 2,500+ cities' },
        { stat: '320M+', label: 'people on our network' },
        { stat: '<1ms', label: '5G Ultra latency' }
      ].forEach(s => { %>
        <div class="bg-gray-50 rounded-2xl p-6">
          <div class="text-3xl font-extrabold text-nexus-600 mb-1"><%= s.stat %></div>
          <div class="text-sm text-gray-500"><%= s.label %></div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- Coverage type explainer -->
<section class="py-12 px-4 bg-gray-50 border-t">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-xl font-bold text-gray-900 mb-6">What do the coverage types mean?</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% [
        {
          color: 'bg-purple-500',
          name: '5G Ultra',
          desc: 'Our fastest 5G available in dense urban areas. Download speeds up to 4 Gbps. Ideal for streaming, gaming, and working remotely.'
        },
        {
          color: 'bg-nexus-500',
          name: '5G Extended',
          desc: 'Wide-area 5G covering suburbs and mid-size cities. Significantly faster than LTE with speeds up to 300 Mbps.'
        },
        {
          color: 'bg-green-500',
          name: '4G LTE',
          desc: 'Reliable nationwide coverage with download speeds up to 100 Mbps. Available in most cities, towns, and along major highways.'
        },
        {
          color: 'bg-yellow-400',
          name: 'Extended LTE',
          desc: 'Coverage in rural and remote areas via our partner network. Speeds and performance may be lower than standard LTE.'
        }
      ].forEach(type => { %>
        <div class="bg-white border rounded-xl p-5 flex items-start gap-4">
          <div class="w-10 h-10 rounded-lg <%= type.color %> flex-shrink-0 opacity-80"></div>
          <div>
            <h3 class="font-bold text-gray-900 mb-1"><%= type.name %></h3>
            <p class="text-sm text-gray-500"><%= type.desc %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<script>
  const zipCoverageMap = {
    '9': { type: '5G Ultra', dot: 'bg-purple-500', dotColor: '#a855f7', desc: 'Excellent 5G Ultra coverage in your area. Expect peak download speeds up to 4 Gbps.', x: 580, y: 180 },
    '1': { type: '5G Extended', dot: 'bg-nexus-500', dotColor: '#4361ee', desc: 'Strong 5G Extended coverage. Download speeds up to 300 Mbps in your area.', x: 250, y: 170 },
    '6': { type: '4G LTE', dot: 'bg-green-500', dotColor: '#22c55e', desc: 'Solid 4G LTE coverage. You\'ll have reliable service for calls, texts, and data.', x: 460, y: 200 },
    '3': { type: '5G Ultra', dot: 'bg-purple-500', dotColor: '#a855f7', desc: 'Excellent 5G Ultra coverage in your area. You\'re in a top-tier coverage zone.', x: 340, y: 290 },
    '7': { type: '5G Extended', dot: 'bg-nexus-500', dotColor: '#4361ee', desc: 'Good 5G Extended coverage available. Enjoy fast speeds throughout your area.', x: 310, y: 220 },
  };
  const defaultCoverage = { type: '4G LTE', dot: 'bg-green-500', dotColor: '#22c55e', desc: 'Good 4G LTE coverage in your area. Reliable for calls, texts, and everyday data use.', x: 400, y: 240 };

  function checkCoverage(e) {
    e.preventDefault();
    const zip = document.getElementById('zip-input').value.trim();
    if (!/^\d{5}$/.test(zip)) return;

    const coverage = zipCoverageMap[zip[0]] || defaultCoverage;

    // Update pin
    const pin = document.getElementById('zip-pin');
    const circle = document.getElementById('pin-circle');
    const ring = document.getElementById('pin-ring');
    const label = document.getElementById('pin-label');
    circle.setAttribute('cx', coverage.x);
    circle.setAttribute('cy', coverage.y);
    ring.setAttribute('cx', coverage.x);
    ring.setAttribute('cy', coverage.y);
    label.setAttribute('x', coverage.x);
    label.setAttribute('y', coverage.y + 30);
    label.textContent = 'ZIP: ' + zip;
    pin.style.display = 'block';

    // Update result card
    const result = document.getElementById('coverage-result');
    document.getElementById('result-dot').style.background = coverage.dotColor;
    document.getElementById('result-type').textContent = coverage.type + ' — ZIP ' + zip;
    document.getElementById('result-desc').textContent = coverage.desc;
    result.classList.remove('hidden');
  }
</script>

<%- include('partials/footer') %>
