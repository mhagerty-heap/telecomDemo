<%- include('../partials/header') %>

<!-- Page Header -->
<section class="bg-gradient-to-br from-nexus-900 to-nexus-700 text-white py-14 px-4 text-center">
  <h1 class="text-4xl font-extrabold mb-3">Shop Devices</h1>
  <p class="text-blue-100 text-lg max-w-xl mx-auto">The latest phones with easy monthly payments. Free shipping on all orders.</p>
</section>

<!-- Filters + Grid -->
<section class="py-10 px-4 bg-gray-50">
  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-8">

    <!-- Filter sidebar -->
    <aside class="lg:w-56 flex-shrink-0">
      <div class="bg-white border rounded-2xl p-5 sticky top-20">
        <h3 class="font-bold text-gray-900 mb-4">Filter</h3>

        <!-- Brand -->
        <div class="mb-5">
          <h4 class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">Brand</h4>
          <div class="space-y-2">
            <% ['All', 'Apple', 'Samsung', 'Google', 'Motorola', 'Nexus'].forEach(brand => { %>
              <label class="flex items-center gap-2 cursor-pointer text-sm text-gray-600 hover:text-gray-900">
                <input type="radio" name="brand" value="<%= brand %>"
                  class="accent-nexus-500"
                  <%= brand === 'All' ? 'checked' : '' %>
                  onchange="filterDevices()">
                <%= brand %>
              </label>
            <% }) %>
          </div>
        </div>

        <!-- Price -->
        <div class="mb-5">
          <h4 class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">Max Price</h4>
          <div class="space-y-2">
            <% [
              { label: 'All prices', value: 9999 },
              { label: 'Under $300', value: 300 },
              { label: 'Under $600', value: 600 },
              { label: 'Under $1000', value: 1000 }
            ].forEach((opt, i) => { %>
              <label class="flex items-center gap-2 cursor-pointer text-sm text-gray-600 hover:text-gray-900">
                <input type="radio" name="maxPrice" value="<%= opt.value %>"
                  class="accent-nexus-500"
                  <%= i === 0 ? 'checked' : '' %>
                  onchange="filterDevices()">
                <%= opt.label %>
              </label>
            <% }) %>
          </div>
        </div>

        <!-- 5G only -->
        <div>
          <label class="flex items-center gap-2 cursor-pointer text-sm text-gray-600 hover:text-gray-900">
            <input type="checkbox" id="filter5g" class="accent-nexus-500" onchange="filterDevices()">
            5G only
          </label>
        </div>

        <button onclick="resetFilters()" id="btn-filter-reset" class="mt-5 w-full text-xs text-gray-400 hover:text-gray-600 text-center">
          Reset filters
        </button>
      </div>
    </aside>

    <!-- Device grid -->
    <div class="flex-1">

      <!-- Sort bar -->
      <div class="flex items-center justify-between mb-5">
        <p class="text-sm text-gray-500"><span id="device-count"><%= devices.length %></span> devices</p>
        <select id="sort-select" onchange="filterDevices()"
          class="text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-nexus-500 bg-white">
          <option value="featured">Featured</option>
          <option value="price-asc">Price: Low to High</option>
          <option value="price-desc">Price: High to Low</option>
          <option value="rating">Top Rated</option>
        </select>
      </div>

      <div id="device-grid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
        <% devices.forEach(device => { %>
          <div class="device-card plan-card bg-white border rounded-2xl overflow-hidden flex flex-col"
            data-brand="<%= device.brand %>"
            data-price="<%= device.price %>"
            data-rating="<%= device.rating %>">

            <!-- Image area -->
            <a href="/devices/<%= device.id %>" id="link-device-image-<%= device.id %>" class="block bg-gray-50 p-8 text-center text-6xl hover:bg-gray-100 transition relative">
              <%= device.emoji %>
              <% if (device.badge) { %>
                <span class="absolute top-3 left-3 bg-nexus-500 text-white text-xs font-bold px-2.5 py-1 rounded-full">
                  <%= device.badge %>
                </span>
              <% } %>
            </a>

            <!-- Info -->
            <div class="p-4 flex flex-col flex-1">
              <div class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5"><%= device.brand %></div>
              <a href="/devices/<%= device.id %>" id="link-device-name-<%= device.id %>" class="font-bold text-gray-900 hover:text-nexus-600 transition mb-1">
                <%= device.name %>
              </a>
              <p class="text-xs text-gray-400 mb-3 flex-1"><%= device.tagline %></p>

              <!-- Rating -->
              <div class="flex items-center gap-1.5 mb-3">
                <div class="flex">
                  <% for(let i = 1; i <= 5; i++) { %>
                    <svg class="w-3.5 h-3.5 <%= i <= Math.round(device.rating) ? 'text-yellow-400' : 'text-gray-200' %>"
                      fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  <% } %>
                </div>
                <span class="text-xs text-gray-400"><%= device.rating %> (<%= device.reviews.toLocaleString() %>)</span>
              </div>

              <!-- Price -->
              <div class="flex items-end justify-between border-t pt-3 mt-auto">
                <div>
                  <% if (device.monthlyPrice) { %>
                    <div class="text-lg font-extrabold text-nexus-600">$<%= device.monthlyPrice %>/mo</div>
                    <div class="text-xs text-gray-400">or $<%= device.price %> outright</div>
                  <% } else { %>
                    <div class="text-lg font-extrabold text-nexus-600">$<%= device.price %></div>
                  <% } %>
                </div>
                <a href="/devices/<%= device.id %>" id="link-device-view-<%= device.id %>"
                  class="bg-nexus-500 hover:bg-nexus-600 text-white text-xs font-bold px-3 py-2 rounded-lg transition">
                  View →
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- No results -->
      <div id="no-results" class="hidden text-center py-16 text-gray-400">
        <div class="text-4xl mb-3">🔍</div>
        <p class="font-medium">No devices match your filters.</p>
        <button onclick="resetFilters()" id="btn-filter-clear" class="mt-3 text-nexus-500 hover:underline text-sm">Clear filters</button>
      </div>

    </div>
  </div>
</section>

<script>
  function filterDevices() {
    const brand = document.querySelector('input[name="brand"]:checked')?.value || 'All';
    const maxPrice = parseInt(document.querySelector('input[name="maxPrice"]:checked')?.value || 9999);
    const only5g = document.getElementById('filter5g').checked;
    const sort = document.getElementById('sort-select').value;

    const cards = Array.from(document.querySelectorAll('.device-card'));
    let visible = [];

    cards.forEach(card => {
      const cardBrand = card.dataset.brand;
      const cardPrice = parseInt(card.dataset.price);
      const matchBrand = brand === 'All' || cardBrand === brand;
      const matchPrice = cardPrice <= maxPrice;
      // All demo devices are 5G so filter just shows/hides toggle effect
      if (matchBrand && matchPrice) {
        card.style.display = '';
        visible.push(card);
      } else {
        card.style.display = 'none';
      }
    });

    // Sort visible cards
    const grid = document.getElementById('device-grid');
    visible.sort((a, b) => {
      if (sort === 'price-asc') return parseInt(a.dataset.price) - parseInt(b.dataset.price);
      if (sort === 'price-desc') return parseInt(b.dataset.price) - parseInt(a.dataset.price);
      if (sort === 'rating') return parseFloat(b.dataset.rating) - parseFloat(a.dataset.rating);
      return 0;
    });
    visible.forEach(card => grid.appendChild(card));

    document.getElementById('device-count').textContent = visible.length;
    document.getElementById('no-results').classList.toggle('hidden', visible.length > 0);
  }

  function resetFilters() {
    document.querySelector('input[name="brand"][value="All"]').checked = true;
    document.querySelector('input[name="maxPrice"]').checked = true;
    document.getElementById('filter5g').checked = false;
    document.getElementById('sort-select').value = 'featured';
    filterDevices();
  }
</script>

<%- include('../partials/footer') %>
