<div class="bg-white border-b py-5 px-4">
  <div class="max-w-2xl mx-auto flex items-center justify-between">
    <% const steps = ['Choose Plan', 'Choose Device', 'Your Info', 'Review & Pay']; %>
    <% steps.forEach((label, i) => { %>
      <% const num = i + 1; %>
      <% const isActive = num === step; %>
      <% const isDone = num < step; %>
      <div class="flex items-center <%= i < steps.length - 1 ? 'flex-1' : '' %>">
        <div class="flex flex-col items-center">
          <div class="step-circle
            <%= isDone ? 'bg-green-500 text-white' : isActive ? 'bg-nexus-500 text-white' : 'bg-gray-200 text-gray-400' %>">
            <% if (isDone) { %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            <% } else { %>
              <%= num %>
            <% } %>
          </div>
          <span class="text-xs mt-1 font-medium hidden sm:block
            <%= isActive ? 'text-nexus-600' : isDone ? 'text-green-600' : 'text-gray-400' %>">
            <%= label %>
          </span>
        </div>
        <% if (i < steps.length - 1) { %>
          <div class="flex-1 h-0.5 mx-2 mb-3 <%= isDone ? 'bg-green-400' : 'bg-gray-200' %>"></div>
        <% } %>
      </div>
    <% }) %>
  </div>
</div>
